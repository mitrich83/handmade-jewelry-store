// ─────────────────────────────────────────────────────────────────────────────
// Prisma schema — Handmade Jewelry Store
// Full models are added in Issue #62 (User, Product, Order, Category)
//                      and Issue #63 (Review, Wishlist + seed script)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Minimal placeholder — expanded in Issue #62
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
